# ────────── BACKEND API ──────────
# Geliştirmede:
#   - Android emulator → http://10.0.2.2:8080/api/v1
#   - iOS simulator    → http://localhost:8080/api/v1
#   - Fiziksel cihaz   → http://192.168.X.X:8080/api/v1 (kendi LAN IP'in)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api/v1


# ────────── GOOGLE MAPS (Android) ──────────
# https://console.cloud.google.com → "Maps SDK for Android" enable et → API key oluştur
# Bu key Android manifest'e gömülür; bundle'a SIZMAZ (EXPO_PUBLIC_ prefix'i YOK).
GOOGLE_MAPS_ANDROID_API_KEY=AIzaSyBD9WT82o0msVxh9RxdKsL9nW5U7LU_uy4


# ────────── GOOGLE OAUTH (opsiyonel) ──────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# 3 ayrı client gerekiyor (iOS, Android, Web). Boş bırakırsan login ekranında Google butonu görünmez.
